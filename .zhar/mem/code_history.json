  "3c4d5": {
    "id": "3c4d5",
    "group": "code_history",
    "node_type": "file_change",
    "summary": "Rewrite PHiveStaticRouter to use BoxCollection/CollectionBox",
    "status": "active",
    "tags": [],
    "source": "phive/lib/src/router/static_router.dart",
    "content": "Full rewrite. Replaced Box<dynamic> with prefixed keys with Hive CE BoxCollection / CollectionBox. _collection holds a BoxCollection opened in ensureOpen(). _boxCache maps box names to CollectionBox<dynamic>. All CRUD uses async CollectionBox.get/put/delete. _assertMutable guards register and createRef after ensureOpen sets _isOpen. Box naming follows the same conventions as PHiveDynamicRouter.",
    "created_at": "2026-04-20T19:30:00Z",
    "updated_at": "2026-04-20T19:30:00Z",
    "expires_at": null,
    "metadata": {
      "agent": "zhar-agent",
      "significance": "fix"
    },
    "custom": {}
  },
  "4d5e6": {
    "id": "4d5e6",
    "group": "code_history",
    "node_type": "file_change",
    "summary": "Add PHiveStaticRouter TDD test group (group 7, 10 tests)",
    "status": "active",
    "tags": [],
    "source": "phive/test/router_test.dart",
    "content": "Added group 7 — PHiveStaticRouter registration lock + full CRUD. 10 tests: register throws after ensureOpen, createRef throws after ensureOpen, ensureOpen idempotent, store/get round-trip, null on missing key, delete, ref entry populated on store, idempotent re-store, deleteContainer removes children and clears ref, deleteWithChildren removes parent and all children. Total test count is now 33 across 7 groups.",
    "created_at": "2026-04-20T19:30:00Z",
    "updated_at": "2026-04-20T19:30:00Z",
